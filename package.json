{
  "name": "ensemble-plugins",
  "version": "5.13.0",
  "private": true,
  "description": "Ensemble Plugin Ecosystem - Modular Claude Code plugins for development workflows",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "validate": "node scripts/validate-all.js && node scripts/validate-version-sync.js && node scripts/lint-model-ids.js",
    "lint:model-ids": "node scripts/lint-model-ids.js",
    "generate": "node scripts/generate-markdown.js",
    "generate:commands": "node scripts/generate-markdown.js --type commands",
    "generate:agents": "node scripts/generate-markdown.js --type agents",
    "generate:watch": "node scripts/generate-markdown.js --watch",
    "generate:validate": "node scripts/generate-markdown.js --validate",
    "generate:opencode": "node scripts/generate-opencode/index.js",
    "generate:pi": "npm run generate --workspace=packages/pi",
    "generate:codex": "node scripts/generate-codex/index.js",
    "install:codex": "node scripts/install-codex-project.js",
    "version:codex": "node scripts/sync-codex-version.js",
    "release-notes": "node scripts/generate-release-notes.js",
    "release-notes:codex": "node scripts/generate-codex-release-notes.js",
    "publish:changed": "node scripts/publish-plugin.js"
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^3.5.3",
    "commander": "^11.0.0",
    "glob": "^10.3.10",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FortiumPartners/ensemble.git"
  },
  "author": "Fortium Partners",
  "license": "MIT"
}
